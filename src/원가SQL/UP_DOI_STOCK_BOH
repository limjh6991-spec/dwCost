CREATE                                                             procedure UP_DOI_STOCK_BOH
(
    @YYYYMM varchar(10),--집계 년/월 설정
    @SITE varchar(2)  --사업장코드 (본사 : HQ, 베트남 : VN)
)
AS
BEGIN
	BEGIN TRY
	
    SET NOCOUNT ON;
    SET LOCK_TIMEOUT 10000; -- 10초로 증가
    SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED; -- 격리 수준 변경
    DECLARE  @Message  NVARCHAR(MAX)='';
    DECLARE  @Message1  NVARCHAR(MAX)='';
   	DECLARE @CNT INT = 0,
   		    @CHECK BIT = 0;

	SET  @Message =  '[START]  ' + CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- 제품BOH집계(DOI_STOCK_BOH) 테이블에 '+@YYYYMM + '월 '
						+ CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + '제품BOH 집계를 시작합니다';
	--데이타 체크	
	SELECT @CNT = count(*)
		FROM DOI_MODEL_MAST
      WHERE yyyymm=@YYYYMM
        and site  =@SITE;
	IF @CNT = 0 BEGIN
		SET  @Message =  @Message + char(10) + '[ERROR] ' + CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- 면적정보(DOI_MODEL_MAST) 테이블에 '+@YYYYMM + '월 '
			 	+@YYYYMM + '월 '+ CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + ' 데이타가 없습니다';
		SET @CHECK = 1;
	END
	
    IF EXISTS (SELECT 1 FROM sys.objects WHERE object_id = OBJECT_ID('DOI_COST') AND type in ('U')) -- 테이블 존재 여부 확인
    BEGIN
		SELECT @CNT = count(*)
			FROM DOI_COST
	      WHERE yyyymm=@YYYYMM
	        and site  =@SITE;
		IF @CNT = 0 BEGIN
			SET  @Message =  @Message + char(10) + '[ERROR] ' + CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- 가공비 배부(DOI_COST) 테이블에 '
					+@YYYYMM + '월 '+ CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + ' 데이타가 없습니다';
			SET @CHECK = 1;
		END
	END
    ELSE
    BEGIN
        SET  @Message =  @Message + char(10) + '[ERROR] ' + '가공비 배부(DOI_COST)테이블이 존재하지 않습니다.';
        SET @CHECK = 1;
    END	

	SELECT @CNT = count(*)
		FROM DOI_STOCK
      WHERE yyyymm=@YYYYMM
        and site  =@SITE;
	IF @CNT = 0 BEGIN
		SET  @Message =  @Message + char(10) + '[ERROR] ' + CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- 제품수불(DOI_STOCK) 테이블에 '
				+@YYYYMM + '월 ' + CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + ' 데이타가 없습니다';
		SET @CHECK = 1;
	END
	IF @CHECK = 1 BEGIN 
		SELECT @Message as retMessage;
		RETURN -1;
	END


		BEGIN TRANSACTION;
		DELETE FROM DOI_STOCK_BOH
		WHERE 1=1
		  AND yyyymm = @YYYYMM
		  AND SITE = @SITE;
			
		SET  @Message =  @Message + char(10) + ' [INFO]  ' + CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- 제품BOH집계(DOI_STOCK_BOH) 테이블에 '+@YYYYMM + '월 '
						+ CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + '제품BOH 데이타 '+CAST(@@ROWCOUNT AS VARCHAR) +'건을 삭제 했습니다';

		with MODEL_OUT단가 AS (
			SELECT
				a.YYYYMM,
				a.SITE,
				a.구분,
				a.model,
				b.inch,
				a.expen_sel,
				max(a.expen_sel명) expen_sel명,
				a.acct_name,
				a.item_name,
				sum(a.out_단가) out_단가,
				sum(a.unit_cost) unit_cost,
				avg(sum(a.out_단가)) over (partition by inch) avg_cost,
				row_number() over (partition by /*구분,a.model*/b.Inch,a.expen_sel,acct_name,item_name order by a.model,a.expen_sel) as rn,
				count(1) over (partition by a.model,a.expen_sel,acct_name,item_name order by a.item_name) as model_구분 -- 모델 구분이 개발,양산 중 하나일때
			FROM
				DOI_COST a 
			left join  DOI_MODEL_MAST b on (a.model=b.model and a.yyyymm=b.yyyymm and a.site=b.site)
			WHERE 1=1
			  AND a.YYYYMM=@YYYYMM --and expen_sel명!='재료비'
			  AND a.SITE=@SITE
	          --AND a.ADJ_YN='Y' --2026.01.06
			GROUP BY
				a.YYYYMM,
				a.SITE,
				a.구분,
				b.inch,
				a.model,
				a.expen_sel,
				a.acct_name,
				a.item_name
			HAVING sum(a.out_단가) > 0
		)
		INSERT INTO DOI_STOCK_BOH	
		(YYYYMM ,SITE ,sel_code ,구분 ,model ,model_type ,expen_sel ,expen_sel명 ,acct_name, item_name, stock ,boh_amt ,조건 ,inch ,boh ,out_단가)
		select
			YYYYMM ,
			SITE ,
			sel_code ,
			구분 ,
			model ,
			model_type ,
			expen_sel ,
			expen_sel명 ,
			acct_name ,
			item_name,
			stock ,
			Final_Boh as boh_amt ,
			조건 ,
			inch ,
			boh ,
			out_단가
		FROM
		(
		select t.*, Base_boh_amt + case when rn=1 then round(Ori_total,0)-Base_total else 0 end as Final_Boh
		FROM (
			select a.*,
				row_number() over (partition by YYYYMM ,SITE ,sel_code ,구분 ,model ,expen_sel,acct_name,item_name order by Ori_boh_amt desc,item_name) as RN,
				sum(Ori_boh_amt)over (partition by YYYYMM ,SITE ,sel_code ,구분 ,model ,expen_sel,acct_name,item_name ) as Ori_total,
				sum(Base_boh_amt) over (partition by YYYYMM ,SITE ,sel_code ,구분 ,model ,expen_sel,acct_name,item_name ) as Base_total
			FROM (	
				select
					a.YYYYMM,
					a.SITE,
					a.sel_code,
					--case when a.stock='개발 창고' then '개발' when a.stock='완제품 창고' then '양산' else '기타' end as 구분,
					case when right(a.model_type,1)='D' then '개발' else '양산' end as 구분,
					a.model,
					a.model_type,
					b.expen_sel,
					b.expen_sel명,
					b.acct_name,
					b.item_name,
					a.stock,
					a.boh * b.out_단가 as Ori_boh_amt,
					round(a.boh * b.out_단가,0) as Base_boh_amt,
					'model_1' 조건,
					b.inch,
					a.boh boh ,
					b.out_단가
				from
					DOI_STOCK a
				inner join MODEL_OUT단가 b on
					(a.model = b.model 
					 and ( b.구분=case when right(a.model_type,1)='D' then '개발' else '양산' end or model_구분=1 )
					 )
				where 1=1	
				  AND a.YYYYMM	= @YYYYMM
				  AND a.SITE	= @SITE
				)a 
			)t
		)Final
		UNION
		select
			YYYYMM ,
			SITE ,
			sel_code ,
			구분 ,
			model ,
			model_type ,
			expen_sel ,
			expen_sel명 ,
			acct_name ,
			item_name ,
			stock ,
			Final_Boh as boh_amt ,
			조건 ,
			inch ,
			boh ,
			out_단가
		FROM
		(		
		select t.*, Base_boh_amt + case when rn=1 then round(Ori_total,0)-Base_total else 0 end as Final_Boh
		FROM (
			select a.*,
				row_number() over (partition by YYYYMM ,SITE ,sel_code ,구분 ,model ,expen_sel,acct_name,item_name order by Ori_boh_amt desc,acct_name) as RN,
				sum(Ori_boh_amt)over (partition by YYYYMM ,SITE ,sel_code ,구분 ,model ,expen_sel,acct_name,item_name ) as Ori_total,
				sum(Base_boh_amt) over (partition by YYYYMM ,SITE ,sel_code ,구분 ,model ,expen_sel,acct_name,item_name ) as Base_total
			FROM (	
				select
					a.YYYYMM,
					a.SITE,
					a.sel_code,
					--case when a.stock='개발 창고' then '개발' when a.stock='완제품 창고' then '양산' else '기타' end as 구분,
					case when right(a.model_type,1)='D' then '개발' else '양산' end as 구분,
					a.model,
					a.model_type,
					b.expen_sel,
					b.expen_sel명,
					b.acct_name,
					b.item_name,
					a.stock,
					a.boh * b.out_단가 as Ori_boh_amt,
					round(a.boh * b.out_단가,0) as Base_boh_amt,
					'model_1' 조건,
					b.inch,
					a.boh ,
					b.out_단가
				from
					DOI_STOCK a
				inner join MODEL_OUT단가 b on
					(a.model = b.model 
					 and ( b.구분=case when right(a.model_type,1)='D' then '개발' else '양산' end or model_구분=1 )
					 )
				where 1=1	
				  AND a.YYYYMM	= @YYYYMM
				  AND a.SITE	= @SITE
				  AND not exists (select 1 from MODEL_OUT단가 c
				  					where 1=1
				  					  and b.model = c.model 
					 				  and c.구분=case when right(a.model_type,1)='D' then '개발' else '양산' end)
				)a 
			)t
		)Final
		UNION
		select
			YYYYMM ,
			SITE ,
			sel_code ,
			구분 ,
			model ,
			model_type ,
			expen_sel ,
			expen_sel명 ,
			acct_name ,
			item_name ,
			stock ,
			Final_Boh as boh_amt ,
			조건 ,
			inch ,
			boh ,
			out_단가
		FROM
		(		
		select t.*, Base_boh_amt + case when rn=1 then round(Ori_total,0)-Base_total else 0 end as Final_Boh
		FROM (
			select a.*,
				row_number() over (partition by YYYYMM ,SITE ,sel_code ,구분 ,model ,expen_sel,acct_name,item_name order by Ori_boh_amt desc,acct_name) as RN,
				sum(Ori_boh_amt)over (partition by YYYYMM ,SITE ,sel_code ,구분 ,model ,expen_sel,acct_name,item_name ) as Ori_total,
				sum(Base_boh_amt) over (partition by YYYYMM ,SITE ,sel_code ,구분 ,model ,expen_sel,acct_name,item_name ) as Base_total
			FROM (	
				select
					a.YYYYMM,
					a.SITE,
					a.sel_code,
					--case when a.stock='개발 창고' then '개발' when a.stock='완제품 창고' then '양산' else '기타' end as 구분,
					case when right(a.model_type,1)='D' then '개발' else '양산' end as 구분,
					a.model,
					a.model_type,
					c.expen_sel,
					c.expen_sel명,
					c.acct_name,
					c.item_name,
					a.stock,
					a.boh * C.out_단가 as Ori_boh_amt,
					round(a.boh * coalesce(c.out_단가,0),0) as Base_boh_amt,
					'inch' 조건,
					b.inch,
					a.boh ,
					coalesce(c.out_단가,0) as out_단가
				from
					DOI_STOCK a
				left join 	DOI_MODEL_MAST b on (a.model=b.model  and a.yyyymm=b.yyyymm and a.site=b.site)
				left join MODEL_OUT단가 c on
					(c.inch = case 	when b.inch in (7.99,8.01) then 8
									when b.inch=7.61 then 7.72 
									when b.inch in(6.86,7.55) then 7.56 else b.inch end
					  and c.rn=1 )
				where 1=1
				  AND a.YYYYMM=@YYYYMM
				  AND a.SITE=@SITE
		  		  AND not exists (select 1 from MODEL_OUT단가 c where a.model=c.model)
				)a 
			)t
		)Final;
		/*select
			a.YYYYMM,
			a.SITE,
			a.sel_code,
			--case when a.stock='개발 창고' then '개발' when a.stock='완제품 창고' then '양산' else '기타' end as 구분,
			case when right(a.model_type,1)='D' then '개발' else '양산' end as 구분,
			a.model,
			a.model_type,
			c.expen_sel,
			c.expen_sel명,
			a.stock,
			round(a.boh * coalesce(c.out_단가,0),0) as boh_amt,
			'inch',
			b.inch,
			a.boh ,
			coalesce(c.out_단가,0)
		from
			DOI_STOCK a
		left join 	DOI_MODEL_MAST b on (a.model=b.model)
		left join MODEL_OUT단가 c on
			(c.inch = case 	when b.inch in (7.99,8.01) then 8
							when b.inch=7.61 then 7.72 
							when b.inch in(6.86,7.55) then 7.56 else b.inch end and c.rn=1)
		where 1=1
		  AND a.YYYYMM=@YYYYMM
		  AND a.SITE=@SITE
		  AND not exists (select 1 from MODEL_OUT단가 c where a.model=c.model);*/
		--order by a.model;

		SET  @Message =  @Message + char(10) + ' [INFO]  ' + CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- 제품BOH집계(DOI_STOCK_BOH) 테이블에 '+@YYYYMM + '월 '
						+ CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + '제품BOH 데이타 '+CAST(@@ROWCOUNT AS VARCHAR) +'건을 입력했습니다';

		
      	SET  @Message =  @Message + char(10) + '  [END]  ' + CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- 제품BOH집계(DOI_STOCK_BOH) 테이블에 '+@YYYYMM + '월 '
				+ CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + '제품BOH 집계 완료했습니다';

		
      	--제품수불금액 집계  START
      	DECLARE @Ret_M nvarchar(MAX)='';
		EXEC UP_DOI_STOCK_COST
			@YYYYMM = @YYYYMM,
			@SITE = @SITE,
			@R_Message = @Ret_M OUTPUT;
      SET  @Message =  @Message + @Ret_M;	
      	--제품수불금액 집계 END
	 --삭제 ( OUT단가 테이블)
      DELETE FROM DOI_STUC
      WHERE yyyymm= @YYYYMM
        and site  = @SITE;
			
	SET  @Message =  @Message + char(10) + char(10) + ' [INFO]  ' + CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- OUT단가(DOI_STUC) 테이블에 '+@YYYYMM + '월 '
						+ CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + ' 단가 데이타 '+CAST(@@ROWCOUNT AS VARCHAR) +'건을 삭제 했습니다';
  /*  
	INSERT INTO DOI_STUC
	select
		YYYYMM,
		SITE,
		EXPEN_SEL,
		EXPEN_SEL명,
		구분,
		MODEL,
		[OUT] as OUT_QTY,
		OUT_AMT,
		OUT_AMT / nullif([OUT],0) AS OUT_UNITCOST
	from	doi_stco
	where 1=1
		and yyyymm = @YYYYMM
		and site = @SITE
		and [OUT] != 0 
		and OUT_AMT != 0;
	
  	  SET  @Message =  @Message + char(10) + ' [INFO]  ' + CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- OUT단가(DOI_STUC) 테이블에 '+@YYYYMM + '월 '
						+ CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + '단가 데이타 '+CAST(@@ROWCOUNT AS VARCHAR) +'건을 입력했습니다';
  
		--RMA OUT
		WITH OUT단가 AS (	
		select	*,
			sum(out_unitcost) over (partition by yyyymm,site,	구분,	model) as model_outuc,
			dense_rank() over (partition by site,	구분,	model order by	yyyymm desc) rn
		from	DOI_STUC
		), RMAOUT AS (
		SELECT
		    T.*,
		    -- [4-3] 최종 보정: 1차 배부액 + (1등에게 잔액 몰아주기)
		    -- IN 금액 보정
		    Base_Amt + CASE WHEN RN = 1 THEN (modelAmt - Sum_Base_Amt) ELSE 0 END AS RMAOUT_Amt
		 FROM(   
			 SELECT 
			    A.*,
			    -- [4-2] 그룹별(비용항목별) 원금액 합계 계산
			    SUM(Base_Amt) OVER (PARTITION BY site, 구분, model) AS Sum_Base_Amt,
			  -- [4-2] 보정 대상 순위 (배부율 높은 순)
			    ROW_NUMBER() OVER (PARTITION BY site, 구분, model order by Base_Amt desc, expen_sel) AS RN
			 FROM(
			    -- [4-1] 1차 배부 계산 (Base Amount)    
				select
					a.yyyymm,a.site,a.sel_code,
					b.구분,b.model,b.expen_sel ,b.expen_sel명,
					a.rma_out as RMAOUT_QTY,
					ROUND(a.rma_out * model_outuc, 0) as modelAmt,
					a.rma_out * b.out_unitcost as Origin_Amt,
					round(a.rma_out*b.out_unitcost,0) as Base_Amt
				FROM	DOI_RMA_INOUT a
				inner join out단가 b ON
					  	(a.yyyymm = b.yyyymm
						and a.site = b.site
						and left(a.도우코드, 4)= b.model
						and b.구분 = case when right(a.도우코드,1)='D' then '개발' else '양산' end
						and b.rn = 1)
				where 1= 1
					and a.yyyymm = @YYYYMM
					and a.site = @SITE
				)a
			)T
		)--select * from rmaout;
		MERGE DOI_STCO AS t
		USING RMAOUT AS s
		    ON  t.YYYYMM = s.YYYYMM
		    AND t.SITE	 = s.SITE
		    AND t.구분	 = s.구분
		    AND t.MODEL  = s.MODEL
		    AND t.EXPEN_SEL = s.EXPEN_SEL
		WHEN MATCHED 
		    THEN UPDATE SET 
		        t.RMAOUT_QTY = s.RMAOUT_QTY,
		        t.RMAOUT_AMT = s.RMAOUT_AMT
		WHEN NOT MATCHED BY TARGET 
		    THEN INSERT (YYYYMM ,SITE ,SEL_CODE ,구분 ,MODEL ,expen_sel ,expen_sel명,RMAOUT_QTY,RMAOUT_AMT)
		        VALUES (s.YYYYMM ,s.SITE ,s.SEL_CODE ,s.구분 ,s.MODEL ,s.expen_sel ,s.expen_sel명,s.RMAOUT_QTY,s.RMAOUT_AMT);
		
  	  SET  @Message =  @Message + char(10) + char(10) + ' [INFO]  ' + CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- 제품수불금액(DOI_STCO) 테이블에 '+@YYYYMM + '월 '
						+ CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + 'RMA OUT 데이타 '+CAST(@@ROWCOUNT AS VARCHAR) +'건을 업데이트 했습니다';
	
		--RMA IN
		WITH OUT단가 AS (	
		select	*,
			sum(out_unitcost) over (partition by yyyymm,site,	구분,	model) as model_outuc,
			dense_rank() over (partition by site,	구분,	model order by	yyyymm desc) rn
		from	DOI_STUC
		), RMAIN AS (
		SELECT
		    T.*,
		    -- [4-3] 최종 보정: 1차 배부액 + (1등에게 잔액 몰아주기)
		    -- IN 금액 보정
		    Base_Amt + CASE WHEN RN = 1 THEN (modelAmt - Sum_Base_Amt) ELSE 0 END AS RMAIN_Amt
		 FROM(   
			 SELECT 
			    A.*,
			    -- [4-2] 그룹별(비용항목별) 원금액 합계 계산
			    SUM(Base_Amt) OVER (PARTITION BY site, 구분, model) AS Sum_Base_Amt,
			    -- [4-2] 보정 대상 순위 (배부율 높은 순)
			    ROW_NUMBER() OVER (PARTITION BY site, 구분, model order by Base_Amt desc, expen_sel) AS RN
			 FROM(
			    -- [4-1] 1차 배부 계산 (Base Amount)    
				select
					a.yyyymm,a.site,a.sel_code,
					b.구분,b.model,b.expen_sel ,b.expen_sel명,
					a.rma_in as RMAIN_QTY,
					ROUND(a.rma_in * model_outuc, 0) as modelAmt,
					a.rma_in * b.out_unitcost as Origin_Amt,
					round(a.rma_in*b.out_unitcost,0) as Base_Amt
				FROM	DOI_RMA_INOUT a
				inner join out단가 b ON
					  	(a.yyyymm = b.yyyymm
						and a.site = b.site
						and left(a.도우코드, 4)= b.model
						and b.구분 = case when right(a.도우코드,1)='D' then '개발' else '양산' end
						and b.rn = 1)
				where 1= 1
					and a.yyyymm = @YYYYMM
					and a.site = @SITE
				)a
			)T
		)--select * from rmain
		MERGE DOI_COST AS t
		USING RMAIN AS s
		    ON  t.YYYYMM = s.YYYYMM
		    AND t.SITE	 = s.SITE
		    AND t.구분	 = s.구분
		    AND t.MODEL  = s.MODEL
		    AND t.EXPEN_SEL = s.EXPEN_SEL
    		AND t.ACCT_NAME != 'CST'
		WHEN MATCHED 
		    THEN UPDATE SET 
		        t.RMAIN_QTY = s.RMAIN_QTY,
		        t.RMAIN_AMT = s.RMAIN_AMT
		WHEN NOT MATCHED BY TARGET 
		    THEN INSERT (YYYYMM ,SITE ,SEL_CODE ,구분 ,MODEL ,expen_sel ,expen_sel명,RMAIN_QTY,RMAIN_AMT)
		        VALUES (s.YYYYMM ,s.SITE ,s.SEL_CODE ,s.구분 ,s.MODEL ,s.expen_sel ,s.expen_sel명,s.RMAIN_QTY,s.RMAIN_AMT); 	  
		
