CREATE             procedure UP_DOI_STOCK_BOH
(
    @YYYYMM varchar(10),--집계 년/월 설정
    @SITE varchar(2)  --사업장코드 (본사 : HQ, 베트남 : VN)
)
AS
BEGIN
	BEGIN TRY
	
    SET NOCOUNT ON;
    SET LOCK_TIMEOUT 10000; -- 10초로 증가
    SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED; -- 격리 수준 변경
    DECLARE  @Message  NVARCHAR(MAX)='';
    DECLARE  @Message1  NVARCHAR(MAX)='';
   	DECLARE @CNT INT = 0,
   		    @CHECK BIT = 0;

	SET  @Message =  '[START]  ' + CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- 제품BOH집계(DOI_STOCK_BOH) 테이블에 '+@YYYYMM + '월 '
						+ CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + '제품BOH 집계를 시작합니다';
	--데이타 체크	
	SELECT @CNT = count(*)
		FROM DOI_MODEL_MAST
      WHERE yyyymm=@YYYYMM
        and site  =@SITE;
	IF @CNT = 0 BEGIN
		SET  @Message =  @Message + char(10) + '[ERROR] ' + CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- 면적정보(DOI_MODEL_MAST) 테이블에 '+@YYYYMM + '월 '
			 	+@YYYYMM + '월 '+ CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + ' 데이타가 없습니다';
		SET @CHECK = 1;
	END
	
    IF EXISTS (SELECT 1 FROM sys.objects WHERE object_id = OBJECT_ID('DOI_FAB_COST') AND type in ('U')) -- 테이블 존재 여부 확인
    BEGIN
		SELECT @CNT = count(*)
			FROM DOI_FAB_COST
	      WHERE yyyymm=@YYYYMM
	        and site  =@SITE;
		IF @CNT = 0 BEGIN
			SET  @Message =  @Message + char(10) + '[ERROR] ' + CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- 가공비 배부(DOI_FAB_COST) 테이블에 '
					+@YYYYMM + '월 '+ CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + ' 데이타가 없습니다';
			SET @CHECK = 1;
		END
	END
    ELSE
    BEGIN
        SET  @Message =  @Message + char(10) + '[ERROR] ' + '가공비 배부(DOI_FAB_COST)테이블이 존재하지 않습니다.';
        SET @CHECK = 1;
    END	

	SELECT @CNT = count(*)
		FROM DOI_STOCK
      WHERE yyyymm=@YYYYMM
        and site  =@SITE;
	IF @CNT = 0 BEGIN
		SET  @Message =  @Message + char(10) + '[ERROR] ' + CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- 제품수불(DOI_STOCK) 테이블에 '
				+@YYYYMM + '월 ' + CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + ' 데이타가 없습니다';
		SET @CHECK = 1;
	END
	IF @CHECK = 1 BEGIN 
		SELECT @Message as retMessage;
		RETURN -1;
	END


		BEGIN TRANSACTION;
		DELETE FROM DOI_STOCK_BOH
		WHERE 1=1
		  AND yyyymm = @YYYYMM
		  AND SITE = @SITE;
			
		SET  @Message =  @Message + char(10) + ' [INFO]  ' + CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- 제품BOH집계(DOI_STOCK_BOH) 테이블에 '+@YYYYMM + '월 '
						+ CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + '제품BOH 데이타 '+CAST(@@ROWCOUNT AS VARCHAR) +'건을 삭제 했습니다';

		with MODEL_OUT단가 AS (
			SELECT
				a.YYYYMM,
				a.SITE,
				a.구분,
				a.model,
				b.inch,
				sum(a.out_단가) out_단가,
				sum(a.unit_cost) unit_cost,
				avg(sum(a.out_단가)) over (partition by inch) avg_cost,
				row_number() over (partition by inch order by a.model) as rn 
			FROM
				DOI_FAB_COST a 
			left join  DOI_MODEL_MAST b on (a.model=b.model and a.yyyymm=b.yyyymm and a.site=b.site)
			WHERE 1=1
			  AND a.YYYYMM=@YYYYMM
			  AND a.SITE=@SITE
			GROUP BY
				a.YYYYMM,
				a.SITE,
				a.구분,
				b.inch,
				a.model
			HAVING sum(a.out_단가) > 0	
		)
		INSERT INTO DOI_STOCK_BOH	
		select
			a.YYYYMM,
			a.SITE,
			a.sel_code,
			case when a.stock='개발 창고' then '개발' when a.stock='완제품 창고' then '양산' else '기타' end as 구분,
			a.model,
			a.model_type,
			a.stock,
			round(a.boh * b.out_단가,0) as boh_amt,
			'model_1' 조건,
			b.inch,
			a.boh ,
			b.out_단가 --select * 
		from
			DOI_STOCK a
		inner join MODEL_OUT단가 b on
			(a.model = b.model 
			 and b.구분=case when a.stock='개발 창고' then '개발' when a.stock='완제품 창고' then '양산' else '기타' end  )
		where 1=1
		  AND a.YYYYMM=@YYYYMM
		  AND a.SITE=@SITE
		UNION 
		select
			a.YYYYMM,
			a.SITE,
			a.sel_code,
			case when a.stock='개발 창고' then '개발' when a.stock='완제품 창고' then '양산' else '기타' end as 구분,
			a.model,
			a.model_type,
			a.stock,
			round(a.boh * b.out_단가,0) as boh_amt,
			'model_2' 구분,
			b.inch,
			a.boh ,
			b.out_단가 --select * 
		from
			DOI_STOCK a
		inner join MODEL_OUT단가 b on	(a.model = b.model)
		where 1=1
		  AND a.YYYYMM=@YYYYMM 
		  AND a.SITE=@SITE
		  AND not exists (select 1 from MODEL_OUT단가 c
		  					where 1=1
		  					  and b.model = c.model 
			 				  and c.구분=case when a.stock='개발 창고' then '개발' when a.stock='완제품 창고' then '양산' else '기타' end)
		UNION
		select
			a.YYYYMM,
			a.SITE,
			a.sel_code,
			case when a.stock='개발 창고' then '개발' when a.stock='완제품 창고' then '양산' else '기타' end as 구분,
			a.model,
			a.model_type,
			a.stock,
			round(a.boh * coalesce(c.avg_cost,0),0) as boh_amt,
			'inch',
			b.inch,
			a.boh ,
			coalesce(c.avg_cost,0)
		from
			DOI_STOCK a
		left join 	DOI_MODEL_MAST b on (a.model=b.model)
		left join MODEL_OUT단가 c on
			(c.inch = case 	when b.inch in (7.99,8.01) then 8
							when b.inch=7.61 then 7.72 
							when b.inch in(6.86,7.55) then 7.56 else b.inch end and c.rn=1)
		where 1=1
		  AND a.YYYYMM=@YYYYMM
		  AND a.SITE=@SITE
		  AND not exists (select 1 from MODEL_OUT단가 c where a.model=c.model)
		order by a.model;

		SET  @Message =  @Message + char(10) + ' [INFO]  ' + CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- 제품BOH집계(DOI_STOCK_BOH) 테이블에 '+@YYYYMM + '월 '
						+ CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + '제품BOH 데이타 '+CAST(@@ROWCOUNT AS VARCHAR) +'건을 입력했습니다';

		
      	SET  @Message =  @Message + char(10) + '  [END]  ' + CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- 제품BOH집계(DOI_STOCK_BOH) 테이블에 '+@YYYYMM + '월 '
				+ CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + '제품BOH 집계 완료했습니다';
		
      	--제품수불금액 집계  START
      	DECLARE @Ret_M nvarchar(MAX)='';
		EXEC UP_DOI_STOCK_COST
			@YYYYMM = @YYYYMM,
			@SITE = @SITE,
			@R_Message = @Ret_M OUTPUT;
      	--제품수불금액 집계 END

  	SET  @Message =  @Message + @Ret_M + char(10) + char(10) + '[START]  ' + CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- 판매관리비배부(DOI_SMCE_COST) 테이블에 '+@YYYYMM + '월 '
						+ CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + '판매관리비 배부를 시작합니다';
	--데이타 체크	
	SELECT @CNT = count(*)
		FROM DOI_ACCT_EXPEN
      WHERE yyyymm=@YYYYMM
        and site  =@SITE;
	IF @CNT = 0 BEGIN
		SET  @Message =  @Message + char(10) + '[ERROR] ' + CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- 부서별/원가항목별 투입비용(DOI_ACCT_EXPEN) 테이블에 '+@YYYYMM + '월 '
			 	+@YYYYMM + '월 '+ CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + ' 데이타가 없습니다';
		SET @CHECK = 1;
	END
	
	SELECT @CNT = count(*)
		FROM DOI_SALE_RESC
      WHERE yyyymm=@YYYYMM
        and site  =@SITE;
	IF @CNT = 0 BEGIN
		SET  @Message =  @Message + char(10) + '[ERROR] ' + CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- 매출정보(DOI_SALE_RESC) 테이블에 '
				+@YYYYMM + '월 ' + CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + ' 데이타가 없습니다';
		SET @CHECK = 1;
	END
	
	IF @CHECK = 1 BEGIN 
		SELECT @Message as retMessage;
		RETURN -1;
	END
	
	--기존 데이타 삭제
		DELETE FROM DOI_SMCE_COST
		WHERE 1=1
		  AND yyyymm = @YYYYMM
		  AND SITE = @SITE;
			
		SET  @Message =  @Message + char(10) + ' [INFO]  ' + CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- 판매관리비배부(DOI_SMCE_COST) 테이블에 '+@YYYYMM + '월 '
						+ CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + '데이타 '+CAST(@@ROWCOUNT AS VARCHAR) +'건을 삭제 했습니다';

      	WITH sale_data AS (
    -- [1] 매출 데이터 및 비율 계산용 기초 데이터
    SELECT
        yyyymm,
        품명 AS model,
        SUM(원화판매금액) AS SALE_AMT
    FROM DOI_SALE_RESC
    WHERE yyyymm = @YYYYMM
      AND site = @SITE
    GROUP BY yyyymm, 품명
),
sale_total AS (
    -- [2] 전체 매출 합계 (분모)
    SELECT SUM(SALE_AMT) AS TOT_SALE_AMT 
    FROM sale_data
),
expen_data AS (
    -- [3] 비용 데이터 (배부 대상)
    SELECT 
        YYYYMM, 
        SITE,
        MAX(ACCT_NAME) AS SUB_NAME,
        MAX(ITEM_NAME) AS ITEM_NAME,
        EXPEN_SEL,
        MIN(EXPEN_SEL명) AS EXPEN_SEL명,
        SUM(ACCT_AMT) AS TOT_ACCT,       -- 개별 비용 항목의 금액
        SUM(SUM(ACCT_AMT)) OVER() AS TOT_SMCE -- 전체 비용 합계 (참고용)
    FROM DOI_ACCT_EXPEN
    WHERE yyyymm = @YYYYMM
      AND site = @SITE
      AND acct_class = 'CC'
    GROUP BY YYYYMM, SITE, EXPEN_SEL
)
INSERT INTO DOI_SMCE_COST
SELECT
    YYYYMM,
    'ACTUAL' AS sel_code,
    SITE,
    '양산' AS 구분,
    model,
    EXPEN_SEL명,
    SUB_NAME,
    ITEM_NAME,
    EXPEN_SEL,
    TOT_ACCT,
    SALE_AMT,
    TOT_AMT,
    TOT_SMCE,
    DIST_RATE,
    -- [최종 보정]
    -- 1차 배부액 + (1위 모델에게 [원본비용 - 배부합계] 차이 반영)
    Base_Dist_Amt + CASE 
        WHEN RN = 1 THEN (TOT_ACCT - Grp_Sum_Amt) 
        ELSE 0 
    END AS DIST_AMT,
    
    DIST_AMT_ORI -- 참고용 원본 계산값
FROM (
    SELECT 
        A.*,
        -- [그룹별 배부액 합계] 비용항목(EXPEN_SEL)별로 배부된 금액의 합
        SUM(Base_Dist_Amt) OVER (PARTITION BY EXPEN_SEL) AS Grp_Sum_Amt,
        
        -- [순위] 단수차를 몰아줄 대상 (매출액이 가장 큰 모델 순)
        ROW_NUMBER() OVER (PARTITION BY EXPEN_SEL ORDER BY SALE_AMT DESC) AS RN
    FROM (
        SELECT
            e.YYYYMM,
            e.SITE,
            s.model,
            e.EXPEN_SEL명,
            e.SUB_NAME,
            e.ITEM_NAME,
            e.EXPEN_SEL,
            e.TOT_ACCT,  -- 이 비용을 배부해야 함
            e.TOT_SMCE,
            s.SALE_AMT,
            t.TOT_SALE_AMT AS TOT_AMT,
            
            -- [비율 계산 수정] * 1.0을 추가하여 실수 연산 유도
            CASE 
                WHEN ISNULL(t.TOT_SALE_AMT, 0) = 0 THEN 0
                ELSE CAST(s.SALE_AMT AS FLOAT) / t.TOT_SALE_AMT 
            END AS DIST_RATE,

            -- [1차 배부액] 반올림 처리
            CASE 
                WHEN ISNULL(t.TOT_SALE_AMT, 0) = 0 THEN 0
                ELSE ROUND(e.TOT_ACCT * (CAST(s.SALE_AMT AS FLOAT) / t.TOT_SALE_AMT), 0)
            END AS Base_Dist_Amt,

            -- [참고용] 소수점 포함 원본 배부액
            e.TOT_ACCT * (CAST(s.SALE_AMT AS FLOAT) / NULLIF(t.TOT_SALE_AMT, 0)) AS DIST_AMT_ORI

        FROM expen_data e
        CROSS JOIN sale_data s -- 모든 비용을 모든 모델에 배부 (1=1 조건과 동일)
        CROSS JOIN sale_total t
    ) A
) Final
ORDER BY model;

		SET  @Message =  @Message + char(10) + ' [INFO]  ' + CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- 판매관리비배부(DOI_SMCE_COST) 테이블에 '+@YYYYMM + '월 '
						+ CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + '판매관리비 데이타 '+CAST(@@ROWCOUNT AS VARCHAR) +'건을 배부했습니다';

		
      	SET  @Message =  @Message + char(10) + '  [END]  ' + CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- 판매관리비배부(DOI_SMCE_COST) 테이블에 '+@YYYYMM + '월 '
				+ CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + '판매관리비 배부 완료했습니다';
      	COMMIT TRANSACTION;   
      	
		SELECT @Message as retMessage;
   
      END TRY
   
   BEGIN CATCH
		SET  @Message =  @Message + char(10) + '[ERROR] '+  CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+(SELECT ERROR_MESSAGE());-- AS ErrorMessage;
		--ROLLBACK TRANSACTION;
		SELECT @Message as retMessage;
   END CATCH;
END;
