CREATE                   Procedure UP_DOI_FAB_COST
(
    @YYYYMM varchar(10),--집계 년/월 설정
    @SITE varchar(2)  --사업장코드 (본사 : HQ, 베트남 : VN)
)
AS
BEGIN
	SET NOCOUNT ON;
    SET LOCK_TIMEOUT 10000; -- 10초로 증가
    SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED; -- 격리 수준 변경
    DECLARE  @Message  NVARCHAR(MAX)=''
    
	SET  @Message =  '[START] ' + CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- 가공비배부(DOI_FAB_COST) 테이블에 '+@YYYYMM + '월 '
						+ CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + '데이타 집계를 시작합니다';
   BEGIN TRY
      BEGIN TRANSACTION;
 		/*DECLARE @YYYYMM VARCHAR(6) = '202507', --집계 년/월 설정
            @SITE   VARCHAR(2) = 'HQ';*/
   	
   DECLARE @CNT INT = 0,
   		   @CHECK BIT = 0;
   
	--데이타 체크
	SELECT @CNT = count(*)
		FROM DOI_ACCT
      WHERE yyyymm=@YYYYMM
        and site  =@SITE;
	IF @CNT = 0 BEGIN
		SET @Message = @Message + char(10) + '[ERROR] ' + CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- 원가계정정보(DOI_ACCT) 테이블에 '+@YYYYMM + '월 '
						+ CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + ' 데이타가 없습니다';
		SET @CHECK = 1;
	END
	
	SELECT @CNT = count(*)
		FROM DOI_EXPEN_MATL
      WHERE yyyymm=@YYYYMM
        and site  =@SITE;
	IF @CNT = 0 BEGIN
		SET @Message =  '[ERROR] ' + CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- 경비집계(DOI_EXPEN_MATL) 테이블에 '+@YYYYMM + '월 '
						+ CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + ' 데이타가 없습니다'; -- as retMessage;
		SET @CHECK = 1;
	END
			
	SELECT @CNT = count(*)
		FROM DOI_CASSETTE_RESC
      WHERE yyyymm=@YYYYMM
        and site  =@SITE;
	IF @CNT = 0 BEGIN
		SET @Message = @Message + char(10)+'[ERROR] '+  CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- 카세트 발생비용(DOI_CASSETTE_RESC) 테이블에 '
				+@YYYYMM + '월 '+ CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + ' 데이타가 없습니다'; --  as retMessage;;
		SET @CHECK = 1;
	END
	
	IF @CHECK = 1 BEGIN 
		SELECT @Message as retMessage;
		RETURN -1;
	END
	
      --삭제
      DELETE FROM DOI_FAB_COST
      WHERE yyyymm=@YYYYMM
        and site  =@SITE
		and acct_name!='재료비';
   	  
     SET  @Message =  @Message + char(10) + ' [INFO] ' + CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- 가공비배부(DOI_FAB_COST) 테이블에 '+@YYYYMM + '월 '
						+ CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + ' 데이타 '+CAST(@@ROWCOUNT AS VARCHAR) +'건을 삭제했습니다';
       
      INSERT INTO DOI_FAB_COST 
      select
         YYYYMM,
         'ACTUAL' as sel_code,
         SITE,
         구분,
         model,
         expen_sel명 acct_name,
         SUB_NAME,
         ITEM_NAME,
         EXPEN_SEL,
         boh_qty,
         in_qty,
         eoh_qty,
         out_qty,
         loss_qty,
         bad_qty,
         transfer_qty,
         unit_cost,
         boh,
         [in],
         /*if boh수량+in수량 = eoh수량 then eoh금액 = boh금액+in금액 else unit_cost * (eoh_qty / 2) */  -- eoh금액 :(단가)*eoh수량/2 
         round(case when boh_qty+in_qty = eoh_qty then boh + "in" else unit_cost * (eoh_qty / 2.0) end,0) as eoh,
         case when out_qty = 0 THEN unit_cost 
         ELSE coalesce((boh + "in"-(unit_cost * (eoh_qty / 2.0)))/ nullif(out_qty+bad_qty+Transfer_qty, 0), 0) end as out_단가, --(boh금액+in금액-eoh금액)/(out수량+bad수량+Transfer수량)
         round(coalesce((boh + "in"-(unit_cost * (eoh_qty / 2.0)))/ nullif(out_qty+bad_qty+Transfer_qty, 0), 0) * out_qty,0) as out, --out금액 : out_단가 * out수량
         --round(case when boh_qty+in_qty = loss_qty then 0 else boh+"in"-(unit_cost * (eoh_qty / 2)) end,0) as out1,
         round(case when boh_qty+in_qty = loss_qty then boh+"in" else 0 end,0) as loss,
         round(coalesce((boh + "in"-(unit_cost * (eoh_qty / 2.0)))/ nullif(out_qty+bad_qty+Transfer_qty, 0), 0) * bad_qty,0)  as bad, --Bad금액 : out_단가 * Bad수량(0)
         round(coalesce((boh + "in"-(unit_cost * (eoh_qty / 2.0)))/ nullif(out_qty+bad_qty+Transfer_qty, 0), 0) * Transfer_qty,0) as transfer --transfer금액 : out_단가 * transfer수량(0)
         --into  DOI_FAB_COST
         /*eoh금액확정
         eoh확정
         out전체금액=boh금액+in금액-eoh금액
         out전체금액/(out수량+bad수량+transfer수량)*out수량 ---out금액
         out전체금액/(out수량+bad수량+transfer수량)*bad수량 ---bad금액
         out전체금액/(out수량+bad수량+transfer수량)*transfer수량 ---transfer금액
         
         out단가*out수량
         out단가*bad수량
         out단가*transfer수량
         
         단수조정 - 추후 발생시 반영
         if out수량이 있으면 out금액 = boh금액+in금액-eoh금액-bad금액-transfer금액
         else if   bad수량이 있으면 bad금액 = boh금액+in금액-eoh금액-out금액-transfer금액
          else if transfer 수량이 있으면 transfer금액 = boh금액+in금액-eoh금액-out금액-bad금액*/
      from
         doi_expen_matl
      where yyyymm = @YYYYMM
        and site = @SITE
        and len(model) <= 5 --카세트팀 제외
      order by
         YYYYMM, SITE,   구분,   model, expen_sel;
  
 	 SET  @Message =  @Message + char(10) + ' [INFO] ' + CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- 가공비배부(DOI_FAB_COST) 테이블에 '+@YYYYMM + '월 '
				+ CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + ' 부서별 데이타 '+CAST(@@ROWCOUNT AS VARCHAR) +'건을 배부했습니다';
      --카세트 팀입력 
      with Cst_distRate as (
      select
         yyyymm,
         site,
         CST_NO,
         sum(IN_QTY) IN_QTY,
         SUM(in_qty) * 1.0 / SUM(SUM(in_qty)) OVER(PARTITION BY yyyymm,site) AS dist_rate
      from   DOI_CASSETTE_RESC
      where 1=1
         and yyyymm = @YYYYMM
         and site = @SITE
      group by
         yyyymm,
         site,
         CST_NO
      ), SUM_CST_TEAM AS(    
      select 
         A.YYYYMM,
         A.SITE,
         B.expen_sel명 as acct_name,
         B.대분류 as SUB_NAME,
         B.소분류 as ITEM_NAME,
         A.EXPEN_SEL,
         SUM(a.ACCT_AMT) amt
      from
         DOI_ACCT_EXPEN a
         Left join doi_acct b on (a.acct=b.acct and a.yyyymm=b.yyyymm and a.site=b.site)
      where 1=1
        and a.yyyymm=@YYYYMM
        and a.site=@SITE
        and a.dept = '448'
      GROUP BY 
         A.YYYYMM,
         A.SITE,
         B.expen_sel명,
         B.대분류,
         B.소분류,
         A.EXPEN_SEL
      )
      INSERT into DOI_FAB_COST 
      (YYYYMM,SEL_CODE,SITE,구분,model,acct_name,SUB_NAME,ITEM_NAME,EXPEN_SEL,IN_QTY,OUT_QTY,[IN],[OUT])
      SELECT
         A.YYYYMM,
         'ACTUAL' as sel_code,
         A.SITE,
         '양산' 구분,
         B.CST_NO model,
         A.acct_name,
         A.SUB_NAME,
         A.ITEM_NAME,
         A.EXPEN_SEL,
         B.IN_QTY AS IN_QTY,
         B.IN_QTY AS OUT_QTY,
         A.AMT * B.DIST_RATE [IN],
         A.AMT * B.DIST_RATE [OUT]
      FROM
         SUM_CST_TEAM A
      LEFT JOIN Cst_distRate B ON (A.YYYYMM=B.YYYYMM AND A.SITE=B.SITE)
      order by B.CST_NO;
     
      SET  @Message =  @Message + char(10) + ' [INFO] ' + CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- 가공비배부(DOI_FAB_COST) 테이블에 '+@YYYYMM + '월 '
						+ CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + '카세스팀 데이타 '+CAST(@@ROWCOUNT AS VARCHAR) +'건을 배부했습니다';
      SET  @Message =  @Message + char(10) + '  [END] ' + CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+'- 가공비배부(DOI_FAB_COST) 테이블에 '+@YYYYMM + '월 '
						+ CASE WHEN @SITE ='HQ' THEN '본사' ELSE 'VINA' END + '데이타 배부 완료했습니다';
   
      COMMIT TRANSACTION; 
      SELECT @Message as retMessage;
      RETURN 0;
      END TRY
   
   BEGIN CATCH
       ROLLBACK TRANSACTION;
       SET  @Message =  @Message + char(10) + '[ERROR] '+  CONVERT(VARCHAR(19), GETDATE(), 120) + char(9)+(SELECT ERROR_MESSAGE());-- AS ErrorMessage;
   		SELECT @Message as retMessage;
   END CATCH;
END;
