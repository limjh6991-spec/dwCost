<mapper namespace="com.dowinsys.cost.web.c0003000.mapper.C0003000Mapper">
    <select id="C0003001_Sch1" resultType="CamelMap">
	EXEC UP_DOI_MAT_AMT 
		#{yyyymm},
		#{site},
		#{selcode}
    </select>
 
	<select id="C0003002_Sch1" resultType="CamelMap">
	EXEC UP_DOI_MAT_COST 
		#{yyyymm},
		#{site},
		#{selcode}
    </select>
 
 	<select id="C0003003_Sch1" resultType="CamelMap">
	EXEC UP_DOI_COST_MAT 
		#{yyyymm},
		#{site},
		#{selcode}
    </select>
       
    <select id="C0003005_Sch1" resultType="CamelMap">
	DECLARE @RET_CODE INT;
	EXEC @RET_CODE = Gen_DOI_COST 
		#{yyyymm},
		#{site}
    </select>
    
    <select id="C0003007_Sch1" resultType="CamelMap">
	DECLARE @RET_CODE INT;
	EXEC @RET_CODE = Gen_EXPEN_MATL 
		#{yyyymm},
		#{site}
    </select>
</mapper>