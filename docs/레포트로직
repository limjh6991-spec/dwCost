DECLARE @YYYY VARCHAR(4)='2025';
WITH GEN_YYYYMM AS (
    SELECT 
        CAST(@YYYY + '0101' AS DATE) AS DT,
        FORMAT(CAST(@YYYY + '0101' AS DATE), 'yyyyMM') AS YYYYMM
    UNION ALL
    SELECT 
        DATEADD(MONTH, 1, DT),
        FORMAT(DATEADD(MONTH, 1, DT), 'yyyyMM') AS YYYYMM
    FROM GEN_YYYYMM
    WHERE DT < CAST(@YYYY + '1201' AS DATE)
)SELECT * INTO #GEN_YYYYMM FROM GEN_YYYYMM;

--구   분
--매출액
--수량 (Cell)
--판가 (단위:원)
SELECT a.YYYYMM,'매출액' as  구분,sum(원화판매금액계) 매출액,sum(수량) as '수량(Cell)',sum(원화판매금액계)/sum(수량) as '판가 (단위:원)'
FROM #GEN_YYYYMM a 
  LEFT JOIN DOI_SALE_RESC b ON (a.YYYYMM=b.YYYYMM and b.SITE='HQ')
GROUP BY a.YYYYMM UNION ALL  
--양산매출
--수량 (Cell)
--판가 (단위:원)
SELECT a.YYYYMM,'양산매출' as  구분,sum(원화판매금액계) 매출액,sum(수량) as '수량(Cell)',sum(원화판매금액계)/sum(수량) as '판가 (단위:원)'
FROM #GEN_YYYYMM a 
  LEFT JOIN DOI_SALE_RESC b ON (a.YYYYMM=b.YYYYMM and b.SITE='HQ' and RIGHT(b.품번,1)!='D')
GROUP BY a.YYYYMM UNION ALL
--개발매출
--수량 (Cell)
--판가 (단위:원)
SELECT a.YYYYMM,'개발매출' as  구분,sum(원화판매금액계) 매출액,sum(수량) as '수량(Cell)',sum(원화판매금액계)/sum(수량) as '판가 (단위:원)'
FROM #GEN_YYYYMM a 
  LEFT JOIN DOI_SALE_RESC b ON (a.YYYYMM=b.YYYYMM and b.SITE='HQ' and RIGHT(b.품번,1)='D')
GROUP BY a.YYYYMM;  

